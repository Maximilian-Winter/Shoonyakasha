#version 450

//
// Bright Extract + Downsample Compute Shader
// 白虎司斷  銳利而除冗
// The White Tiger governs cutting — sharp blade extracts the bright
//

layout(local_size_x = 16, local_size_y = 16) in;

layout(binding = 0) uniform sampler2D sceneColor;
layout(binding = 1, rgba16f) writeonly uniform image2D bloomOutput;

layout(binding = 2) uniform BloomParams {
    float threshold;
    float softKnee;
    float intensity;
    float padding;
} params;

void main() {
    ivec2 outputSize = imageSize(bloomOutput);
    ivec2 coord = ivec2(gl_GlobalInvocationID.xy);

    if (coord.x >= outputSize.x || coord.y >= outputSize.y) return;

    // Sample scene at half resolution (2x2 box filter)
    vec2 texelSize = 1.0 / vec2(textureSize(sceneColor, 0));
    vec2 uv = (vec2(coord) + 0.5) / vec2(outputSize);

    // 4-tap bilinear downsample
    vec3 color = vec3(0.0);
    color += texture(sceneColor, uv + vec2(-0.5, -0.5) * texelSize).rgb;
    color += texture(sceneColor, uv + vec2( 0.5, -0.5) * texelSize).rgb;
    color += texture(sceneColor, uv + vec2(-0.5,  0.5) * texelSize).rgb;
    color += texture(sceneColor, uv + vec2( 0.5,  0.5) * texelSize).rgb;
    color *= 0.25;

    // Luminance-based thresholding with soft knee
    float luma = dot(color, vec3(0.2126, 0.7152, 0.0722));
    float knee = params.threshold * params.softKnee;
    float soft = luma - params.threshold + knee;
    soft = clamp(soft, 0.0, 2.0 * knee);
    soft = soft * soft / (4.0 * knee + 0.0001);

    float contribution = max(soft, luma - params.threshold) / max(luma, 0.0001);
    color *= contribution * params.intensity;

    imageStore(bloomOutput, coord, vec4(color, 1.0));
}
